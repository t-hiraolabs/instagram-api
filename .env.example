# Anthropic API Key（バックエンド経由での管理を推奨）
EXPO_PUBLIC_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Instagram Graph API
# Facebook Developer Console で取得
EXPO_PUBLIC_INSTAGRAM_APP_ID=your_instagram_app_id
EXPO_PUBLIC_INSTAGRAM_APP_SECRET=your_instagram_app_secret

# 本番環境用バックエンドURL
EXPO_PUBLIC_API_BASE_URL=https://your-backend.com/api

# Supabase（予約投稿機能）
# Supabase Dashboard > Settings > API で取得
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
